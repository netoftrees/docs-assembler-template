{
    "version": "1.0.0",
    "name": "docs-assembler-assets",
    "contents": [
        {
            "source": "build/assets",
            "dest": "docs/assets/FragmentRenderer",
            "type": "directory",
            "strategy": "cleanOverwrite",
            "description": "Built JS/CSS — always replace entirely"
        },
        {
            "source": "docs/_includes",
            "dest": "docs/_includes",
            "type": "directory",
            "strategy": "addOnly"
        },
        {
            "source": "docs/_layouts",
            "dest": "docs/_layouts",
            "type": "directory",
            "strategy": "addOnly"
        },
        {
            "source": "docs/assets/images",
            "dest": "docs/assets/images",
            "type": "directory",
            "strategy": "addOnly",
            "description": "Static images — don't overwrite user customizations"
        },
        {
            "source": "docs/assets/scss",
            "dest": "docs/assets/scss",
            "type": "directory",
            "strategy": "addOnly"
        },
        {
            "source": "docs/_config.yml",
            "dest": "docs/_config.yml",
            "type": "file",
            "strategy": "skipIfExists",
            "description": "Jekyll config — user may customize"
        },
        {
            "source": "docs/404.html",
            "dest": "docs/404.html",
            "type": "file",
            "strategy": "skipIfExists"
        },
        {
            "source": ".templates",
            "dest": ".templates",
            "type": "directory",
            "strategy": "skipIfExists",
            "description": "Custom templates — only on first init"
        },
        {
            "source": ".gitattributes",
            "dest": "root/.gitattributes",
            "type": "file",
            "strategy": "merge",
            "mergeType": "lineByLine",
            "description": "Append new patterns to existing .gitattributes"
        },
        {
            "source": ".gitignore",
            "dest": "root/.gitignore",
            "type": "file",
            "strategy": "merge",
            "mergeType": "lineByLine",
            "description": "Append new patterns to existing .gitignore"
        }
    ],
    "routing": {
        "docs/": "{docsFolder}/",
        ".templates/": ".templates/",
        "root/": ""
    }
}