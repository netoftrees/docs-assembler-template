{
  "version": "1.0.0",
  "zipName": "docs-assembler-assets.zip",
  "routing": {
    "docs/": "{docsFolder}/",
    "tsmaps/": "{tsmapsFolder}/",
    ".templates/": ".templates/",
    "root/": ""
  },
  "contents": [
    {
      "path": "docs/_includes/",
      "type": "directory",
      "description": "Jekyll includes"
    },
    {
      "path": "docs/_layouts/",
      "type": "directory",
      "description": "Jekyll layouts"
    },
    {
      "path": "docs/assets/FragmentRenderer/",
      "type": "directory",
      "description": "Built JS/CSS assets",
      "generated": true
    },
    {
      "path": "docs/assets/images/",
      "type": "directory",
      "description": "Static images"
    },
    {
      "path": "docs/assets/scss/",
      "type": "directory",
      "description": "SCSS partials"
    },
    {
      "path": "docs/_config.yml",
      "type": "file",
      "description": "Jekyll configuration",
      "ifMissing": true
    },
    {
      "path": "docs/404.html",
      "type": "file",
      "description": "404 error page"
    },
    {
      "path": "tsmaps/",
      "type": "directory",
      "description": "Default map templates",
      "ifMissing": true
    },
    {
      "path": ".templates/videoUrlJson.tstml",
      "type": "file",
      "description": "Video URL template",
      "ifMissing": true
    },
    {
      "path": "root/.gitattributes",
      "type": "file",
      "target": ".gitattributes",
      "ifMissing": true
    }
  ],
  "builtAssets": [
    {
      "path": "docs/assets/FragmentRenderer/guide.[hash].js",
      "original": "guide.js"
    },
    {
      "path": "docs/assets/FragmentRenderer/stepHook.[hash].js",
      "original": "stepHook.js"
    },
    {
      "path": "docs/assets/FragmentRenderer/styles.[hash].css",
      "original": "styles.css"
    }
  ]
}