{
  "name": "docs-assembler-help",
  "version": "0.0.11",
  "author": "netoftrees",
  "type": "module",
  "scripts": {
    "ck": "tsc --noEmit",
    "dev": "vite",
    "build": "tsc && vite build --mode production",
    "min-build": "tsc && npx vite build --config vite-min.config.js",
    "serve": "vite preview --port 1223",
    "update:docs": "tsx _scripts/update-docs-assets.ts",
    "build:docs": "yarn build && yarn update:docs",
    "package:dist": "tsx _scripts/package-assets.ts",
    "build:package": "yarn build:docs && yarn package:dist",
    "release:package": "yarn build:package && tsx _scripts/release.ts",
    "build:jekyll": "jekyll build",
    "modify:html": "node _scripts/modify-html.js",
    "build-modify:jekyll": "yarn build:jekyll && yarn modify:html",
    "build-modify:jekyll-dev": "yarn build:jekyll && yarn modify:html && vite"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@vitejs/plugin-basic-ssl": "^1.0.1",
    "archiver": "^7.0.1",
    "sass": "*",
    "timing-object": "^3.1.96",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "*",
    "vite-plugin-mkcert": "^1.16.0",
    "vite-plugin-static-copy": "^2.3.0",
    "yarn": "^1.22.22"
  },
  "dependencies": {
    "@vimeo/player": "^2.30.2",
    "concurrently": "^9.2.1",
    "jsdom": "^26.1.0"
  },
  "volta": {
    "node": "24.12.0",
    "yarn": "1.22.22",
    "typescript": "5.9.3"
  }
}